pipeline {
    agent any

    stages {

        stage('Acessibilidade') {
            steps {
                sh '''
                    set -e

                    # Verifica se a aplicacao esta respondendo
                    curl -fsS http://172.17.0.1:8080 >/dev/null || { echo "Aplicacao inacessivel"; exit 1; }

                    # Executa o scan de acessibilidade com pa11y (WCAG2AA)
                    npx -y pa11y@latest http://172.17.0.1:8080 --standard WCAG2AA --reporter cli
                '''
            }
        }

    }
}