pipeline {
    agent any

    stages {

        stage('Acessibilidade') {
            steps {
                withCredentials([sshUserPrivateKey(credentialsId: 'jenkins', keyFileVariable: 'keyfile', usernameVariable: 'username')]) {
                    sh """
                        set -e

                        ssh -o StrictHostKeyChecking=no -i "$keyfile" "$username@teste-devops" '
                            set -e

                            # Verifica se a aplicacao esta respondendo
                            curl -fsS http://teste-devops >/dev/null || { echo "Aplicacao inacessivel em http://teste-devops"; exit 1; }

                            # Executa o scan de acessibilidade com pa11y (WCAG2AA)
                            npx -y pa11y@latest http://teste-devops --standard WCAG2AA --reporter cli
                        '
                    """
                }
            }
        }

    }
}
